# ContribKit Environment Variables Example
# Copy this file to .env and fill in your production values

DJANGO_SETTINGS_MODULE=contribkit.settings.prod
SECRET_KEY=replace-this-with-a-long-random-secret-key-in-production
DEBUG=False
ALLOWED_HOSTS=yourusername.pythonanywhere.com,localhost,127.0.0.1

# Database Configuration (MySQL on PythonAnywhere or sqlite3)
DB_ENGINE=sqlite3
# DB_ENGINE=mysql
# DB_NAME=yourusername$contribkit
# DB_USER=yourusername
# DB_PASSWORD=your_mysql_password
# DB_HOST=yourusername.mysql.pythonanywhere-services.com
# DB_PORT=3306

# HTTPS Security Settings
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000

# Optional GitHub Personal Access Token (PAT) for higher rate limits (5000/hr instead of 60/hr)
# GITHUB_PAT=ghp_examplepersonalaccesstoken
